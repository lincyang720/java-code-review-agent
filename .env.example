# ============================================
# Java Code Review Agent 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值

# --------------------------------------------
# DeepSeek API 配置（推荐，国内访问）
# --------------------------------------------
# DeepSeek API Key（默认使用 DeepSeek，性价比高）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# --------------------------------------------
# OpenAI API 配置（可选，需要代理）
# --------------------------------------------
# 如需使用 OpenAI，取消下面注释并配置
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# 如果使用 Azure OpenAI，取消下面注释并配置
# OPENAI_BASE_URL=https://your-resource.openai.azure.com

# --------------------------------------------
# GitLab 配置（公司内网）
# --------------------------------------------
# GitLab 服务器地址
GITLAB_URL=http://192.168.1.151

# GitLab 个人访问令牌（需要有 api 权限）
# 在 GitLab 中生成：User Settings -> Access Tokens
GITLAB_TOKEN=your_gitlab_token_here

# --------------------------------------------
# GitHub 配置（可选）
# --------------------------------------------
# GitHub 个人访问令牌
GITHUB_TOKEN=your_github_token_here

# --------------------------------------------
# 应用配置（可选，使用默认值可不填）
# --------------------------------------------
# 服务器端口
# SERVER_PORT=8080

# 日志级别
# LOG_LEVEL=DEBUG

# AI 调用超时时间（ISO 8601 格式，默认 120 秒）
# 代码审查任务可能需要较长时间，如仍超时可调大
# AI_TIMEOUT=PT120S

# --------------------------------------------
# SonarQube 配置（可选，需要本地服务）
# --------------------------------------------
# 如需启用 SonarQube 分析，取消下面注释并配置
# SONAR_TOKEN=your_sonar_token_here
# SONAR_PROJECT_KEY=your_project_key

# --------------------------------------------
# SpotBugs 配置（可选，需要本地安装）
# --------------------------------------------
# SpotBugs 默认通过 application.yml 配置，无需环境变量
# 如需自定义可执行路径，可在 application.yml 中设置
# executable-path: /path/to/spotbugs
